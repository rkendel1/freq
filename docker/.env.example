# Freqtrade Docker Development Environment Variables
# Copy this file to .env and customize for your setup
#
# Usage:
#   docker compose -f docker-compose.dev.yml --env-file docker/.env up

# ============================================================================
# CORE SETTINGS
# ============================================================================

# Run in dry-run mode (no real trades)
# Set to 'false' for paper trading or live trading (BE CAREFUL!)
DRY_RUN=true

# Initial capital amount in USD/USDT
INITIAL_CAPITAL=10000.0

# Exchange to connect to (any CCXT-supported exchange)
# Examples: binance, hyperliquid, bybit, okx, kraken, kucoin, coinbase, dydx
EXCHANGE_NAME=binance

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# SECURITY
# ============================================================================

# Password for Configuration Dashboard (port 8501)
# IMPORTANT: Set this to protect your config dashboard!
# Leave empty to disable password protection (NOT RECOMMENDED for production)
STREAMLIT_PASSWORD=

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Process throttle (seconds between exploit module evaluations)
PROCESS_THROTTLE_SECS=5

# Enable detailed debug logging for specific modules
# DEBUG_EXCHANGE=false
# DEBUG_RISK=false
# DEBUG_EXPLOITS=false

# ============================================================================
# QUESTDB INTEGRATION (Future Feature)
# ============================================================================

# Enable QuestDB for time-series metrics logging
# Requires QuestDB service to be uncommented in docker-compose.dev.yml
QUESTDB_ENABLED=false
QUESTDB_HOST=questdb
QUESTDB_PORT=9000

# QuestDB metrics configuration
# QUESTDB_TABLE_PREFIX=freqtrade_
# QUESTDB_BATCH_SIZE=100
# QUESTDB_FLUSH_INTERVAL=10

# ============================================================================
# EXCHANGE API CREDENTIALS
# ============================================================================

# WARNING: Never commit real API keys to version control!
# Use these only for testing or mount a secure config file
#
# For production, it's better to:
# 1. Use the Configuration Dashboard (port 8501) to set keys, OR
# 2. Mount a secure config file with credentials, OR
# 3. Use Docker secrets or environment-specific secret management

# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=
# EXCHANGE_API_PASSPHRASE=  # Only needed for some exchanges (e.g., KuCoin)

# ============================================================================
# CUSTOM MODULES
# ============================================================================

# Path to custom ExploitModules (if mounting separately)
# CUSTOM_EXPLOITS_PATH=/freqtrade/custom_exploits

# Python path for custom modules
# PYTHONPATH=/freqtrade:/freqtrade/custom_exploits

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Auto-refresh interval for monitoring dashboard (seconds)
MONITOR_REFRESH_INTERVAL=10

# Maximum log lines to display in dashboards
MAX_LOG_LINES=500

# Enable Prometheus metrics endpoint (future feature)
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090

# ============================================================================
# DEVELOPMENT OPTIONS
# ============================================================================

# Enable hot reload for code changes (requires volume mount of source)
# HOT_RELOAD=false

# Enable development mode with additional debugging
# DEVELOPMENT_MODE=false

# Skip supervisor and run single process (for debugging)
# SINGLE_PROCESS_MODE=false
# SINGLE_PROCESS_NAME=freqtrade  # Options: freqtrade, demo_ui, config_dashboard, monitor_dashboard
