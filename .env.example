# FreqTrade Adaptive RL Trading Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# BINANCE API CREDENTIALS
# =============================================================================
# Get these from your Binance account (API Management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# =============================================================================
# ADAPTIVE THROTTLING CONFIGURATION
# =============================================================================
# Enable/disable adaptive throttling
ADAPTIVE_THROTTLING_ENABLED=true

# Minimum throttle time in seconds (fast response)
MIN_THROTTLE=1.2

# Maximum throttle time in seconds (when system is under load)
MAX_THROTTLE=8.0

# Additional overhead for RL model inference (TensorFlow/PyTorch)
RL_MODEL_OVERHEAD=0.8

# Factor for API rate limiting (1.5 = 50% safety margin)
API_RATE_FACTOR=1.5

# =============================================================================
# FREQTRADE CONFIGURATION
# =============================================================================
# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Timezone for logs and scheduling
TZ=Europe/Berlin

# =============================================================================
# DOCKER RESOURCE LIMITS
# =============================================================================
# CPU limit for the container (adjust based on your system)
DOCKER_CPU_LIMIT=4.0
DOCKER_CPU_RESERVATION=2.0

# Memory limit for the container (adjust based on your system)
DOCKER_MEMORY_LIMIT=8G
DOCKER_MEMORY_RESERVATION=4G

# =============================================================================
# FREQAI/RL SPECIFIC SETTINGS
# =============================================================================
# Number of CPU cores for RL training (should match your rl_config.cpu_count)
FREQAI_CPU_COUNT=8

# TensorBoard update interval
TENSORBOARD_RELOAD_INTERVAL=30

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
# FreqTrade API server settings
FREQTRADE_API_PORT=8090
FREQTRADE_API_USERNAME=admin
FREQTRADE_API_PASSWORD=SpotRL2025Secure!

# TensorBoard port
TENSORBOARD_PORT=6007

# Jupyter port (for development)
JUPYTER_PORT=8888

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to true to enable Jupyter notebook service
ENABLE_JUPYTER=false

# Set to true to enable TensorBoard monitoring
ENABLE_TENSORBOARD=true

# Set to true to enable detailed debug logging
DEBUG_MODE=false