# =============================================================================
# FreqTrade Docker Environment Configuration Template
# =============================================================================
# Copy this file to .env and customize for your environment
# cp .env.docker.example .env
#
# IMPORTANT: Never commit .env file with real credentials!
# =============================================================================

# =============================================================================
# FREQTRADE CONFIGURATION
# =============================================================================

# Operating mode: dry_run, live
FREQTRADE_MODE=dry_run

# Strategy to use
FREQTRADE_STRATEGY=SampleStrategy

# Timeframe (1m, 5m, 15m, 1h, 4h, 1d)
FREQTRADE_TIMEFRAME=5m

# =============================================================================
# EXCHANGE CONFIGURATION
# =============================================================================
# Get API credentials from your exchange account
# NEVER commit real credentials to version control!

# Exchange name (binance, kraken, coinbase, etc.)
EXCHANGE_NAME=binance

# API credentials (required for live trading)
EXCHANGE_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here
# EXCHANGE_PASSWORD=  # Some exchanges require password

# Exchange specific options
EXCHANGE_CCXT_ASYNC_CONFIG_ENABLERATELIMIT=true

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================

# API server settings
FREQTRADE_API_ENABLED=true
FREQTRADE_API_PORT=8080
FREQTRADE_API_USERNAME=freqtrade
FREQTRADE_API_PASSWORD=your-secure-password-here

# CORS settings (comma-separated origins)
FREQTRADE_API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT secret (generate with: openssl rand -hex 32)
FREQTRADE_API_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (debug, info, warning, error, critical)
LOG_LEVEL=info

# Log file location
LOG_FILE=/freqtrade/user_data/logs/freqtrade.log

# Timezone for logs (e.g., Europe/Berlin, America/New_York, UTC)
TZ=UTC

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL
# SQLite (default):
DB_URL=sqlite:////freqtrade/user_data/tradesv3.sqlite

# PostgreSQL (recommended for production):
# DB_URL=postgresql://freqtrade:password@postgresql:5432/freqtrade

# =============================================================================
# DOCKER RESOURCE LIMITS
# =============================================================================

# CPU limits (number of cores, e.g., 2.0 = 2 cores)
DOCKER_CPU_LIMIT=4.0
DOCKER_CPU_RESERVATION=2.0

# Memory limits (e.g., 4G, 8G)
DOCKER_MEMORY_LIMIT=4G
DOCKER_MEMORY_RESERVATION=2G

# =============================================================================
# FREQAI CONFIGURATION
# =============================================================================

# Enable FreqAI
FREQAI_ENABLED=false

# CPU count for training
FREQAI_CPU_COUNT=4

# TensorBoard settings
TENSORBOARD_ENABLED=false
TENSORBOARD_PORT=6006
TENSORBOARD_RELOAD_INTERVAL=30

# =============================================================================
# TELEGRAM CONFIGURATION
# =============================================================================

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode
DEBUG_MODE=false

# Enable Jupyter notebook
ENABLE_JUPYTER=false
JUPYTER_PORT=8888
JUPYTER_TOKEN=your-jupyter-token

# Development image tag
DEV_IMAGE_TAG=develop

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup directory
BACKUP_DIR=./backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Docker network subnet
DOCKER_NETWORK_SUBNET=172.28.0.0/16

# Bind to localhost only (recommended for security)
# Set to 0.0.0.0 to allow external access (use with caution!)
BIND_HOST=127.0.0.1

# =============================================================================
# PROMETHEUS MONITORING (Optional)
# =============================================================================

PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

# =============================================================================
# POSTGRESQL DATABASE (Optional)
# =============================================================================

POSTGRES_ENABLED=false
POSTGRES_DB=freqtrade
POSTGRES_USER=freqtrade
POSTGRES_PASSWORD=freqtrade-password
POSTGRES_PORT=5432

# =============================================================================
# REDIS CACHE (Optional)
# =============================================================================

REDIS_ENABLED=false
REDIS_PORT=6379
REDIS_PASSWORD=redis-password

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Run as non-root user
PUID=1000
PGID=1000

# Disable privileged mode
DOCKER_PRIVILEGED=false

# Read-only root filesystem (advanced)
DOCKER_READ_ONLY_ROOT=false

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Stake currency
STAKE_CURRENCY=USDT

# Stake amount
STAKE_AMOUNT=100

# Max open trades
MAX_OPEN_TRADES=3

# Dry run wallet
DRY_RUN_WALLET=1000

# Update check interval
UPDATE_CHECK_INTERVAL=1d

# Heartbeat interval (seconds)
HEARTBEAT_INTERVAL=60

# Process only new candles
PROCESS_ONLY_NEW_CANDLES=true

# =============================================================================
# NOTES
# =============================================================================
# 1. Copy this file to .env and customize values
# 2. Never commit .env file with real credentials
# 3. Use docker secrets for production deployments
# 4. Regularly rotate API keys and passwords
# 5. Use strong passwords (min 16 characters)
# 6. Enable 2FA on exchange accounts
# 7. Limit API key permissions (no withdrawal rights)
# 8. Monitor logs for suspicious activity
# =============================================================================
